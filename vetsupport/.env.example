DATABASE_URL=postgresql+psycopg://vetsupport:vetsupport@localhost:5432/vetsupport
OPENAI_API_KEY=

# Embedding provider for the index/search commands.
# Use "openai" (default, requires OPENAI_API_KEY) or "fake" for offline runs.
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# LLM provider for the ask command.
# Use "openai" (default, requires OPENAI_API_KEY) or "fake" for offline runs.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

